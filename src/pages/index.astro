---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Presentation from '../components/Presentation.astro';
import Newsletter from '../components/Newsletter.astro';
import Essais from '../components/Essais.astro';
import Citations from '../components/Citations.astro';
import Projets from '../components/Projets.astro';
import Stats from '../components/Stats.astro';
import Reseaux from '../components/Reseaux.astro';
import Quiz from '../components/Quiz.astro';
---

<Layout>
  <Hero />
  <Presentation />
  <Newsletter />
  <Essais />
  <Citations />
  <Projets />
  <Stats />
  <Reseaux />
  <Quiz />
  <footer class="footer">
    <div class="container footer__inner">
      <span class="footer__logo">Intracogito</span>
      <p class="footer__copy">
        © {new Date().getFullYear()} — Philosophie appliquée.
        Tous droits réservés.
      </p>
      <nav class="footer__nav" aria-label="Navigation pied de page">
        <a href="#accueil">Haut de page ↑</a>
        <a href="#newsletter">Newsletter</a>
        <a href="#essais">Essais</a>
      </nav>
    </div>
  </footer>
</Layout>

<style>
  .footer {
    background-color: var(--color-bg-dark);
    color: rgba(253,250,244,0.4);
    padding-block: var(--space-lg);
    border-top: 1px solid rgba(212,197,169,0.08);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-md);
  }

  .footer__logo {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: rgba(253,250,244,0.6);
    letter-spacing: 0.05em;
  }

  .footer__copy {
    font-size: 0.7rem;
    text-align: center;
    max-width: none;
  }

  .footer__nav {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-md);
  }

  .footer__nav a {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color var(--transition);
  }

  .footer__nav a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-sm);
    }

    .footer__nav {
      justify-content: center;
    }
  }
</style>
