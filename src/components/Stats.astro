---
const stats = [
  { valeur: '1 200+', label: 'Abonnés', detail: 'à la newsletter Cogito' },
  { valeur: '52',     label: 'Éditions', detail: 'publiées à ce jour' },
  { valeur: '80+',    label: 'Heures', detail: 'de contenu produit' },
  { valeur: '5',      label: 'Essais', detail: 'longs en circulation' },
];
---

<section class="section section--dark" id="statistiques">
  <div class="container">
    <header class="stats__header">
      <span class="label">En chiffres</span>
      <h2>L'univers Intracogito.</h2>
    </header>

    <dl class="stats__grid">
      {stats.map((s) => (
        <div class="stats__item">
          <dt class="stats__val">{s.valeur}</dt>
          <dd class="stats__label">{s.label}</dd>
          <dd class="stats__detail">{s.detail}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .stats__header {
    margin-bottom: var(--space-xl);
  }

  .stats__header .label {
    color: var(--color-primary);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: var(--space-lg) 0;
    border-top: 1px solid rgba(212,197,169,0.15);
  }

  .stats__val {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1;
  }

  .stats__label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-cream);
    margin-top: 0.4rem;
  }

  .stats__detail {
    font-size: 0.78rem;
    color: rgba(253,250,244,0.4);
  }

  @media (max-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }
  }
</style>
